:root {
  --mst-bg: #f8fafc;
  --mst-surface: #ffffff;
  --mst-primary: #2563eb;
  --mst-accent: #7c3aed;
  --mst-border: #e2e8f0;
  --mst-text: #0f172a;
  --mst-muted: #64748b;

  --mst-radius: 10px;
  --mst-spacing: 24px;
}

.motion-step-transition-page {
  min-height: 100vh;
  background: var(--mst-bg);
  font-family:
    -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue",
    Arial, sans-serif;
  color: var(--mst-text);
  padding: 48px 24px;
}

.motion-step-transition-wizard {
  max-width: 520px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.motion-step-transition {
  position: relative;
  min-height: 200px;
  overflow: hidden;
}

.motion-step-transition-hidden {
  display: none;
}

.motion-step-transition-card {
  background: var(--mst-surface);
  border: 1px solid var(--mst-border);
  border-radius: var(--mst-radius);
  padding: var(--mst-spacing);
}

.motion-step-transition-card__title {
  margin: 0 0 8px;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--mst-text);
}

.motion-step-transition-card__description {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--mst-muted);
}

.motion-step-transition-progress {
  display: flex;
  gap: 8px;
  justify-content: center;
}

.motion-step-transition-progress__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--mst-border);
  transition: background 0.2s ease;
}

.motion-step-transition-progress__dot--active {
  background: var(--mst-primary);
}

.motion-step-transition-controls {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

.motion-step-transition-button {
  appearance: none;
  border: 1px solid var(--mst-border);
  background: var(--mst-surface);
  color: var(--mst-text);
  font: inherit;
  font-weight: 600;
  font-size: 0.9rem;
  padding: 10px 20px;
  border-radius: var(--mst-radius);
  cursor: pointer;
  transition:
    border-color 0.2s ease,
    background 0.2s ease;
}

.motion-step-transition-button:hover:not(:disabled) {
  border-color: var(--mst-primary);
  background: #eef2ff;
}

.motion-step-transition-button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.motion-step-transition-button:focus {
  outline: none;
}

.motion-step-transition-button:focus-visible {
  outline: 3px solid var(--mst-accent);
  outline-offset: 2px;
}

.slide-left {
  animation-name: motion-step-transition-slide-left;
  animation-duration: 350ms;
  animation-timing-function: ease-out;
  animation-fill-mode: both;
}

.slide-right {
  animation-name: motion-step-transition-slide-right;
  animation-duration: 350ms;
  animation-timing-function: ease-out;
  animation-fill-mode: both;
}

@keyframes motion-step-transition-slide-left {
  from {
    opacity: 0;
    transform: translateX(40px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes motion-step-transition-slide-right {
  from {
    opacity: 0;
    transform: translateX(-40px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@media (max-width: 480px) {
  .motion-step-transition-page {
    padding: 32px 16px;
  }

  .motion-step-transition-card {
    padding: 18px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .slide-left,
  .slide-right {
    animation-duration: 1ms !important;
    animation-delay: 0ms !important;
  }
}
